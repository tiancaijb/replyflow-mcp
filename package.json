  "description": "MCP server for managing Twitter replies — list, generate drafts, copy to clipboard",
  "type": "commonjs",
  "bin": {
    "replyflow-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
